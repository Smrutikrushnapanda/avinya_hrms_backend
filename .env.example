# Database
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
DB_SSL=true

# Cloudinary Configuration
# Add these to your .env file with your actual credentials

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Example with the provided credentials:
# CLOUDINARY_CLOUD_NAME=Avinya_hrms
# CLOUDINARY_API_KEY=238141762368973
# CLOUDINARY_API_SECRET=Bdk2qUsJZw0rvbtbfl89-qihPos

# Optional: if you still have old relative file keys from a previous storage provider,
# set a public base URL so the app can convert those keys into full URLs.
# LEGACY_STORAGE_BASE_URL=https://your-storage-host.example.com
